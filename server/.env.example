# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_long_random_string
JWT_REFRESH_SECRET=replace_with_different_long_random_string

# Admin API header secret
ADMIN_SECRET=replace_with_admin_secret

# Your deployed frontend origin (no trailing slash)
CLIENT_URL=https://your-frontend-domain.com

# Email (SendGrid)
SENDGRID_API_KEY=SG.xxxxxxxx

# App
NODE_ENV=production
PORT=5000
